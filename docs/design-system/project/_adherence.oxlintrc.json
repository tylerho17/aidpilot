      {
        "selector": "JSXOpeningElement[name.name='StatusPanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|eyebrow|title|children|trailing|className|style|key|ref|className|style|children)$/]",
        "message": "<StatusPanel> doesn't accept that prop. Declared props: tone, icon, eyebrow, title, children, trailing, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPanel'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|amber|coral|blue)$/]",
        "message": "<StatusPanel> tone must be one of 'green' | 'amber' | 'coral' | 'blue'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|active|onChange|className|style|key|ref|className|style|children)$/]",
        "message": "<TabBar> doesn't accept that prop. Declared props: tabs, active, onChange, className, style."
