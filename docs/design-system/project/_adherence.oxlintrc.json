{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/buttons/**",
              "components/cards/**",
              "components/data-display/**",
              "components/forms/**",
              "components/icon/**",
              "components/product/**",
              "ui_kits/app/**",
              "ui_kits/marketing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Nunito|Hanken Grotesk|Rubik))/i]",
        "message": "Font not provided by the design system. Available: Nunito, Hanken Grotesk, Rubik."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:initials|src|alt|size|onBrand|className|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: initials, src, alt, size, onBrand, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|icon|dot|className|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, icon, dot, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|amber|coral|blue|gray)$/]",
        "message": "<Badge> tone must be one of 'green' | 'amber' | 'coral' | 'blue' | 'gray'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|shape|iconLeft|iconRight|loading|fullWidth|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, shape, iconLeft, iconRight, loading, fullWidth, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|clay)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'clay'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:rounded|pill)$/]",
        "message": "<Button> shape must be one of 'rounded' | 'pill'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|lift|padding|radius|as|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, lift, padding, radius, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:flat|clay)$/]",
        "message": "<Card> variant must be one of 'flat' | 'clay'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|disabled|id|className|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, label, disabled, id, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChecklistItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:done|title|sub|badge|badgeTone|popping|divider|onToggle|className|style|key|ref|className|style|children)$/]",
        "message": "<ChecklistItem> doesn't accept that prop. Declared props: done, title, sub, badge, badgeTone, popping, divider, onToggle, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChecklistItem'] > JSXAttribute[name.name='badgeTone'] > Literal[value!=/^(?:green|amber|coral|blue|gray)$/]",
        "message": "<ChecklistItem> badgeTone must be one of 'green' | 'amber' | 'coral' | 'blue' | 'gray'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|tone|title|children|badge|badgeTone|className|style|key|ref|className|style|children)$/]",
        "message": "<FeatureCard> doesn't accept that prop. Declared props: icon, tone, title, children, badge, badgeTone, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|green|amber|coral|brand)$/]",
        "message": "<FeatureCard> tone must be one of 'blue' | 'green' | 'amber' | 'coral' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCard'] > JSXAttribute[name.name='badgeTone'] > Literal[value!=/^(?:green|amber|coral|blue|gray)$/]",
        "message": "<FeatureCard> badgeTone must be one of 'green' | 'amber' | 'coral' | 'blue' | 'gray'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|strokeWidth|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, strokeWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute[name.name='name'] > Literal[value!=/^(?:plane|grid|clipboard|file|calendar|letter|gear|shield|shield-check|calendar-check|star|bookmark|check|arrow-right|chevron-left|chevron-down|x|plus)$/]",
        "message": "<Icon> name must be one of 'plane' | 'grid' | 'clipboard' | 'file' | 'calendar' | 'letter' | 'gear' | 'shield' | 'shield-check' | 'calendar-check' | 'star' | 'bookmark' | 'check' | 'arrow-right' | 'chevron-left' | 'chevron-down' | 'x' | 'plus'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|variant|size|active|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, variant, size, active, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|ghost|solid)$/]",
        "message": "<IconButton> variant must be one of 'soft' | 'ghost' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|tone|size|radius|strokeWidth|className|style|key|ref|className|style|children)$/]",
        "message": "<IconTile> doesn't accept that prop. Declared props: icon, tone, size, radius, strokeWidth, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconTile'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|green|amber|coral|brand)$/]",
        "message": "<IconTile> tone must be one of 'blue' | 'green' | 'amber' | 'coral' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|on|size|className|style|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: variant, on, size, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:full|mark|wordmark)$/]",
        "message": "<Logo> variant must be one of 'full' | 'mark' | 'wordmark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='on'] > Literal[value!=/^(?:light|brand)$/]",
        "message": "<Logo> on must be one of 'light' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|active|on|tag|href|onClick|className|style|key|ref|className|style|children)$/]",
        "message": "<NavItem> doesn't accept that prop. Declared props: icon, label, active, on, tag, href, onClick, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute[name.name='on'] > Literal[value!=/^(?:brand|light)$/]",
        "message": "<NavItem> on must be one of 'brand' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='OptionCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:selected|onClick|icon|title|description|className|style|key|ref|className|style|children)$/]",
        "message": "<OptionCard> doesn't accept that prop. Declared props: selected, onClick, icon, title, description, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:pct|fill|height|track|label|showValue|className|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: pct, fill, height, track, label, showValue, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|eyebrowTone|title|subtitle|action|align|size|className|style|key|ref|className|style|children)$/]",
        "message": "<SectionHeading> doesn't accept that prop. Declared props: eyebrow, eyebrowTone, title, subtitle, action, align, size, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='eyebrowTone'] > Literal[value!=/^(?:blue|green|amber|coral)$/]",
        "message": "<SectionHeading> eyebrowTone must be one of 'blue' | 'green' | 'amber' | 'coral'."
