      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|green|amber|coral)$/]",
        "message": "<StatCard> tone must be one of 'blue' | 'green' | 'amber' | 'coral'."
